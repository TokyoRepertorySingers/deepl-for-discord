# Discord bot credentials (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=***
# Application (client) ID — used to register application commands
DISCORD_CLIENT_ID=***
# Optional: register commands to a single guild during development (instant update)
DISCORD_GUILD_ID=

# DeepL API
DEEPL_AUTH_KEY=***
# Set to 1 when using the DeepL API Free plan (different endpoint; otherwise 401)
DEEPL_FREE_API_PLAN=1
# Default target languages offered by the manual translation command
DEEPL_RUNNER_LANGUAGES=en,ja,zh,de,fr,it,es,nl,pl,pt,ru

# HTTP health server (Render free Web Service + GAS keep-alive)
PORT=3000

# debug | info | warn | error
LOG_LEVEL=info
